/* ---------- Match pairs ---------- */
function runMatch(block){
  const pairs = block.pairs;
  total = pairs.length;
  idx = 0;
  updateStats();

  document.getElementById("question").innerText = "جفت‌ها را کامل کن: (یک مورد از چپ + یک مورد از راست)";
  const content = document.getElementById("content");

  const left = shuffle(pairs.map(p=>p[0]));
  const right = shuffle(pairs.map(p=>p[1]));

  let selL=null, selR=null;
  let matchedCount = 0;

  content.innerHTML = `
    <div class="pairwrap">
      <div class="paircol">
        <h4>مورد</h4>
        <div id="L"></div>
      </div>
      <div class="paircol">
        <h4>کارکرد/توضیح</h4>
        <div id="R"></div>
      </div>
    </div>
    <div class="small" style="margin-top:10px">هر جفت درست = ۱ امتیاز.</div>
  `;

  const L = content.querySelector("#L");
  const R = content.querySelector("#R");

  function isCorrect(a,b){
    return pairs.some(p=>p[0]===a && p[1]===b);
  }
  function updateMatchProgress(){
    document.getElementById("sQ").innerText = `${matchedCount}/${total}`;
    document.getElementById("sScore").innerText = score;
  }

  left.forEach(txt=>{
    const b=document.createElement("button");
    b.className="pairbtn";
    b.innerText=txt;
    b.onclick=()=>{
      if(b.classList.contains("matched")) return;
      [...L.querySelectorAll(".pairbtn")].forEach(x=>x.classList.remove("selected"));
      b.classList.add("selected"); selL=txt;
      attempt();
    };
    L.appendChild(b);
  });
  right.forEach(txt=>{
    const b=document.createElement("button");
    b.className="pairbtn";
    b.innerText=txt;
    b.onclick=()=>{
      if(b.classList.contains("matched")) return;
      [...R.querySelectorAll(".pairbtn")].forEach(x=>x.classList.remove("selected"));
      b.classList.add("selected"); selR=txt;
      attempt();
    };
    R.appendChild(b);
  });

  function attempt(){
    if(!selL || !selR) return;
    const ok = isCorrect(selL, selR);
    if(ok){
      score++;
      matchedCount++;
      notice("✅ جفت درست!");
      const lb = [...L.querySelectorAll(".pairbtn")].find(x=>x.innerText===selL);
      const rb = [...R.querySelectorAll(".pairbtn")].find(x=>x.innerText===selR);
      lb.classList.remove("selected"); rb.classList.remove("selected");
      lb.classList.add("matched"); rb.classList.add("matched");
      lb.disabled=true; rb.disabled=true;
      selL=null; selR=null;
      updateMatchProgress();
      if(matchedCount===total){
        finishGame("همه جفت‌ها کامل شد 👌");
      }
    }else{
      notice("❌ این جفت درست نیست.");
      setTimeout(()=>{
        [...L.querySelectorAll(".pairbtn")].forEach(x=>x.classList.remove("selected"));
        [...R.querySelectorAll(".pairbtn")].forEach(x=>x.classList.remove("selected"));
        selL=null; selR=null;
      }, 350);
    }
  }

  document.getElementById("hint").innerText = "هدف: همه جفت‌ها را کامل کن.";
  document.getElementById("startBtn").innerText = "در حال بازی";
  document.getElementById("sTime").innerText = "—";
  updateMatchProgress();
}

/* ---------- Memory ---------- */
function runMemory(){
  document.getElementById("question").innerText = "حافظه جفت‌ها: کارت‌ها را پیدا کن!";
  document.getElementById("hint").innerText = "روی دو کارت بزن؛ اگر مثل هم بودند، می‌مانند.";

  const content = document.getElementById("content");

  // کارت‌ها را بسته به پایه کمی متفاوت می‌کنیم
  const sets = {
    7:["⚡","⚡","📘","📘","🔬","🔬","⭐","⭐","🧠","🧠","🎯","🎯"],
    8:["🧩","🧩","📗","📗","🧪","🧪","🎮","🎮","🧠","🧠","🏁","🏁"],
    9:["🧠","🧠","📐","📐","🧬","🧬","🚀","🚀","🎯","🎯","🏆","🏆"]
  };
  const cards = shuffle(sets[currentGrade] || sets[8]);

  let open = [];
  let matched = new Set();

  content.innerHTML = `
    <div class="options" id="mem" style="grid-template-columns:repeat(4,minmax(60px,1fr));"></div>
    <div class="small" style="margin-top:10px">امتیاز = تعداد جفت‌های پیدا شده.</div>
  `;
  const mem = content.querySelector("#mem");

  function flip(i){
    if(matched.has(i) || open.includes(i) || open.length===2) return;
    mem.children[i].innerText = cards[i];
    open.push(i);

    if(open.length===2){
      const [a,b] = open;
      const ok = cards[a]===cards[b];
      setTimeout(()=>{
        if(ok){
          matched.add(a); matched.add(b);
          score++;
          notice("✅ جفت پیدا شد!");
          document.getElementById("sScore").innerText = score;
          document.getElementById("sQ").innerText = `${score}/${total}`;
          if(score===total) finishGame("همه جفت‌ها کامل شد 👌");
        }else{
          mem.children[a].innerText="❓";
          mem.children[b].innerText="❓";
          notice("❌ جفت نبود.");
        }
        open=[];
      }, 450);
    }
  }

  for(let i=0;i<cards.length;i++){
    const b=document.createElement("button");
    b.className="optbtn";
    b.style.minHeight="58px";
    b.innerText="❓";
    b.onclick=()=>flip(i);
    mem.appendChild(b);
  }

  document.getElementById("startBtn").innerText = "در حال بازی";
  document.getElementById("sTime").innerText = "—";
  document.getElementById("sQ").innerText = `0/${total}`;
}

