/* =========================================================
   2) بانک سوال: (برای هر بازی، برای هر پایه) + مولدهای سؤال
   - نکته: برای جلوگیری از تکرار، بعضی بازی‌ها علاوه بر بانک ثابت، مولد سؤال هم دارند.
   ========================================================= */

/* ---------- ابزارهای کمکی ---------- */
const rand = (a,b)=> Math.floor(Math.random()*(b-a+1))+a;
const pick = (arr)=> arr[Math.floor(Math.random()*arr.length)];
function shuffle(arr){
  // Fisher-Yates
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}
function uniqById(items){
  const seen=new Set();
  const out=[];
  for(const x of items){
    if(!x || !x.__id) continue;
    if(seen.has(x.__id)) continue;
    seen.add(x.__id);
    out.push(x);
  }
  return out;
}
function numToPersian(n){
  const map={'0':'۰','1':'۱','2':'۲','3':'۳','4':'۴','5':'۵','6':'۶','7':'۷','8':'۸','9':'۹','-':'−'};
  return String(n).replace(/[0-9-]/g, ch=>map[ch]||ch);
}

