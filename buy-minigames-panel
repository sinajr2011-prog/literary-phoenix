      return mcqQ(`دنباله: ${seq.join(", ")}, ؟`, options, ans, `دو مرحله‌ای`);
    }

    // grade 9
    const kind=pick(["formula","alt2","quad"]);
    if(kind==="formula"){
      const n=rand(4,8);
      const f = (k)=> k*k - k; // n^2-n
      const seq=[f(1),f(2),f(3),f(4)];
      const ans=f(5);
      const options=shuffle([ans, f(6), ans+2, ans-2]);
      return mcqQ(`دنباله با جمله nام: n²−n. دنباله: ${seq.join(", ")}, ؟`, options, ans);
    }
    if(kind==="alt2"){
      // alternating with two rules
      const a=rand(1,6), b=rand(10,20);
      const seq=[a,b,a+2,b-3,a+4];
      const ans=b-6;
      const options=shuffle([ans, b-3, b-9, b-12]);
      return mcqQ(`دنباله: ${seq.join(", ")}, ؟`, options, ans, `تناوب دو قانون`);
    }
    // quad
    const s=[1,4,9,16,25];
    const take=pick([4,5]);
    const seq=s.slice(0,take);
    const ans=s[take];
    const options=shuffle([ans, ans+2*take+1, ans-1, ans+7]);
    return mcqQ(`دنباله: ${seq.join(", ")}, ؟`, options, ans, `الگوی مربعات`);
  },

  math_percent: (grade)=>{
    if(grade===7){
      const p=pick([10,20,25,50]);
      const base=pick([40,60,80,100,120,200]);
      const ans=base*p/100;
      const options=shuffle([ans, ans+base/10, ans-base/10, ans+base/20].map(x=>Math.round(x)));
      return mcqQ(`${p}٪ از ${base} ؟`, options, Math.round(ans));
    }
    if(grade===8){
      // increase/decrease
      const p=pick([10,15,20,25,30]);
      const base=pick([80,120,150,200,240,300]);
      const inc=pick([true,false]);
      const ans=base*(100+(inc?p:-p))/100;
      const options=shuffle([ans, base, base*(100+(inc?(p+5):(p-5)))/100, base*(100+(inc?(p-5):(p+5)))/100].map(x=>Math.round(x)));
      return mcqQ(`${inc?"افزایش":"کاهش"} ${p}٪ روی ${base}، نتیجه؟`, options, Math.round(ans));
    }
    // grade 9: successive percent
    const base=pick([200,240,300,360,400]);
    const p1=pick([10,15,20,25]);
    const p2=pick([10,15,20]);
    const inc1=pick([true,false]);
    const inc2=pick([true,false]);
    const after1=base*(100+(inc1?p1:-p1))/100;
    const after2=after1*(100+(inc2?p2:-p2))/100;
    const ans=Math.round(after2);
    const options=shuffle([ans, Math.round(after1), Math.round(base*(100+p1+p2)/100), Math.round(base*(100+(inc1?p1:-p1)+(inc2?p2:-p2))/100)]);
    return mcqQ(`عدد ${base} ابتدا ${inc1?"افزایش":"کاهش"} ${p1}٪ و سپس ${inc2?"افزایش":"کاهش"} ${p2}٪ دارد. نتیجه؟`, options, ans);
  },

  math_primehunt: (grade)=>{
    // تبدیل به «اول/بخش‌پذیری/تجزیه» تا برای نهم هم ساده نباشد
    if(grade===7){
      const correctPrime=pick([29,31,37,41,43,47,53,59]);
      const comp=pick([21,27,33,35,39,49,51,55,57]);
      const other=pick([25,45,63,77,91]);
      const options=shuffle([correctPrime, comp, other, comp+2]);
      return mcqQ("کدام عدد اول است؟", options, correctPrime, "یادت باشد: ۲ تنها عدد اولِ زوج است.");
    }
    if(grade===8){
      // divisibility trick
      const n=pick([198,234,252,288,306,315,342,360,378,396]);
      const q = `عدد ${n} بر کدام عدد حتماً بخش‌پذیر است؟`;
      const options=[3,9,6,12].map(String);
      // compute
      let ans=3;
      if(n%9===0) ans=9;
      else if(n%12===0) ans=12;
      else if(n%6===0) ans=6;
      const shuffled=shuffle(options);
      return mcqQ(q, shuffled, String(ans), "بخش‌پذیری را هوشمند بررسی کن.");
    }
    // grade 9: gcd/lcm with primes
    const a=pick([30,42,60,70,84,90,96,105]);
    const b=pick([36,48,63,72,80,98,120,140]);
    const g=gcd(a,b);
    const l=(a*b)/g;
    const ask=pick(["gcd","lcm"]);
    if(ask==="gcd"){
      const options=shuffle([g, g*2, g/2, g+6].map(x=>Math.round(x)));
      return mcqQ(`ب.م.مِ ${a} و ${b} کدام است؟`, options, g, "تجزیه به عوامل اول کمک می‌کند.");
    } else {
      const options=shuffle([l, l/2, l*2, l+10].map(x=>Math.round(x)));
      return mcqQ(`ک.م.مِ ${a} و ${b} کدام است؟`, options, l);
    }
  },

  math_fraction: (grade)=>{
    if(grade===7){
      // compare fractions with close values
      const a=rand(1,7), b=rand(a+1,12);
      const c=rand(1,7), d=rand(c+1,12);
      const v1=a/b, v2=c/d;
      const bigger = v1>v2 ? `${a}/${b}` : `${c}/${d}`;
      const options=shuffle([`${a}/${b}`,`${c}/${d}`,`${a+1}/${b}`,`${c+1}/${d}`]);
      return mcqQ("کدام کسر بزرگ‌تر است؟", options, bigger);
    }
    if(grade===8){
      // simplify / equivalent fraction
      const k=pick([2,3,4,5]);
      const a=rand(1,9), b=rand(a+1,12);
      const num=a*k, den=b*k;
      const options=shuffle([`${a}/${b}`,`${num}/${den}`,`${a}/${den}`,`${num}/${b}`]);
      return mcqQ(`کدام کسر با ${num}/${den} برابر است؟`, options, `${a}/${b}`, "ساده‌سازی کن.");
    }
    // grade 9: rational comparison using cross-multiplication trick
    const a=rand(1,9), b=rand(2,10), c=rand(1,9), d=rand(2,10);
    const left=a/b, right=c/d;
    const sign= left>right ? "بزرگ‌تر" : "کوچک‌تر";
    const correct = left>right ? `${a}/${b}` : `${c}/${d}`;
    const options=shuffle([`${a}/${b}`,`${c}/${d}`,`${a+1}/${b}`,`${c+1}/${d}`]);
    return mcqQ(`کدام کسر ${sign} است؟`, options, correct, "ضرب‌چلیپایی (Cross) کمک می‌کند.");
  },
};

/* ---------- کمک برای ساخت MCQ با گزینه‌های عددی/متنی ---------- */
function mcqQ(question, options, correctValue, exp){
  // correctValue ممکن است عدد یا رشته باشد
  const corr = String(correctValue);
  const opts = options.map(String);
  const answerIndex = opts.findIndex(x=>x===corr);
  // اگر به‌خاطر تصادف پیدا نشد، اصلاح
  const fixedOpts = answerIndex>=0 ? opts : (()=>{
    const f=[...opts];
    f[0]=corr;
    return shuffle(f);
  })();
  const idx = fixedOpts.findIndex(x=>x===corr);
  return {q:question, options:fixedOpts, answer:idx, exp:exp||"" , __id: "mcq:"+hashStr(question+"|"+fixedOpts.join(",")+"|"+corr) };
}

/* ---------- gcd ---------- */
function gcd(a,b){ a=Math.abs(a); b=Math.abs(b); while(b){ [a,b]=[b,a%b]; } return a; }

/* =========================================================
   3) ضدتکرار: نگهداری تاریخچه استفاده‌شده (برای هر بازی+پایه)
   ========================================================= */
function usedKey(gameId, grade){ return `PHOENIX_USED_${gameId}_${grade}`; }
function loadUsed(gameId, grade){
  try{
    const raw = localStorage.getItem(usedKey(gameId,grade));
    const arr = raw ? JSON.parse(raw) : [];
    return new Set(arr);
  }catch{ return new Set(); }
}
function saveUsed(gameId, grade, set){
  // محدودیت برای حجم: 250 مورد آخر
  const arr = Array.from(set).slice(-250);
  localStorage.setItem(usedKey(gameId,grade), JSON.stringify(arr));
}
function resetAllUsed(){
  // تمام کلیدهای used را پاک می‌کنیم
  const keys=[];
  for(let i=0;i<localStorage.length;i++){
    const k=localStorage.key(i);
    if(k && k.startsWith("PHOENIX_USED_")) keys.push(k);
  }
  keys.forEach(k=>localStorage.removeItem(k));
  notice("✅ تاریخچه ضدتکرار پاک شد (از این به بعد سوال‌ها از اول چرخه می‌شوند).");
}

