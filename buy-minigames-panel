/* =========================================================
   9) هش برای idهای ضدتکرار
   ========================================================= */
function hashStr(str){
  // hash سبک (djb2)
  let h=5381;
  for(let i=0;i<str.length;i++){
    h=((h<<5)+h) ^ str.charCodeAt(i);
  }
  return (h>>>0).toString(16);
}

/* =========================================================
   10) Hash Router (اختیاری)
   ========================================================= */
function goFromHash(){
  const h = (location.hash||"").replace("#","");
  if(!h) return;
  const g = GAMES.find(x=>x.id===h);
  if(g){
    if(!currentGrade){ openGradeModal(); return; }
    openGame(h);
  }
}
window.addEventListener("hashchange", goFromHash);
goFromHash();
