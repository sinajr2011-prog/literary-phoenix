/* =========================================================
   7) ساخت Pool سوالات (ثابت + مولد) و ضدتکرار
   ========================================================= */
function buildPool(gameId, grade){
  // used history
  usedSet = loadUsed(gameId, grade);

  // static questions
  const staticList = (DB[gameId] && DB[gameId][grade]) ? DB[gameId][grade] : [];
  const staticWithId = staticList.map((q,i)=> ({...q, __id: q.__id || `${gameId}:${grade}:S:${i}:${hashStr(JSON.stringify(q))}`}));

  // add generated questions for "big bank"
  const genFn = GENERATORS[gameId];
  const generated = [];
  if(typeof genFn==="function"){
    // تولید چند سوال جدید (هر بار 40 تا) تا احساس تکرار خیلی کم شود
    let guard=0;
    while(generated.length<40 && guard<250){
      guard++;
      const q = genFn(grade);
      if(!q || !q.__id) continue;
      if(usedSet.has(q.__id)) continue; // ضدتکرار
      generated.push(q);
    }
  }

  // ترکیب و شافل
  const combined = shuffle(uniqById([...staticWithId, ...generated]));

  // اگر همه اینها در used بودند، used را سبک می‌کنیم (برای جلوگیری از قفل شدن)
  // (در عمل با مولدها کمتر پیش می‌آید)
  return combined;
}

function getNextQuestionFromPool(){
  // اگر pool خالی شد، دوباره بساز
  if(pool.length===0){
    pool = buildPool(currentGame.id, currentGrade);
    // اگر باز هم خالی بود:
    if(pool.length===0) return null;
  }

  // از انتها pop، ولی اگر used بود رد کن
  let tries=0;
  while(pool.length && tries<200){
    tries++;
    const q = pool.pop();
    if(!q || !q.__id) continue;
    if(usedSet && usedSet.has(q.__id)) continue;
    // mark used
    if(usedSet){
      usedSet.add(q.__id);
      saveUsed(currentGame.id, currentGrade, usedSet);
    }
    return q;
  }

  return null;
}

/* =========================================================
   8) Game Engine (نوع‌های بازی)
   ========================================================= */
function buildGameIntro(){
  const type = currentGame.type;
  const hint = {
    mcq:"روش: گزینه درست را انتخاب کن.",
    tf:"روش: «درست/غلط» را انتخاب کن.",
    order:"روش: روی آیتم‌ها بزن تا به ترتیب درست چیده شوند.",
    pickWord:"روش: روی کلمه‌ی غلط/نامتعارف کلیک کن.",
    match:"روش: یک مورد از ستون چپ و یکی از راست را انتخاب کن تا جفت شوند.",
    memory:"روش: کارت‌ها را برگردان و جفت‌ها را پیدا کن.",
    clicker:"روش: فقط کلیک کن تا امتیاز بالا بره!",
    timed_mcq:"روش: در زمان محدود پاسخ بده."
  }[type] || "روش: بازی را شروع کن.";

  document.getElementById("hint").innerText = hint + " (سوال‌ها بر اساس پایه تنظیم شده‌اند.)";
}

function startCurrent(){
  if(!currentGrade){ openGradeModal(); return; }
  if(!currentGame) return;

  stopTimer();
  resetRuntime(false);

  // special games
  if(currentGame.type==="memory"){
    total = 6; // جفت‌ها
    updateStats();
    runMemory();
    document.getElementById("startBtn").innerText = "در حال بازی";
    return;
  }
  if(currentGame.type==="clicker"){
    total = 1;
    idx = 1;
    updateStats();
    startTimer(currentGame.seconds || 10);
    runClicker();
    document.getElementById("startBtn").innerText = "در حال بازی";
    return;
  }
  if(currentGame.type==="match"){
    // از DB ثابت استفاده می‌کنیم
    const block = (DB[currentGame.id] && DB[currentGame.id][currentGrade] && DB[currentGame.id][currentGrade][0]) ? DB[currentGame.id][currentGrade][0] : null;
    if(!block){ notice("❌ برای این پایه سوالی وجود ندارد."); return; }
    runMatch(block);
    document.getElementById("startBtn").innerText = "در حال بازی";
    return;
  }

  // pool
  pool = buildPool(currentGame.id, currentGrade);
  if(!pool.length){
    notice("❌ برای این بازی در این پایه سوالی پیدا نشد.");
    return;
  }

  // تعداد سوالات هر دست بازی (برای اینکه بازی‌ها سریع و جذاب باشند)
  // در صورت مولد بودن، بی‌نهایت ممکن است؛ ما برای هر دور 12 سوال می‌دهیم.
  total = currentGame.type==="timed_mcq" ? 9999 : Math.min(12, pool.length + 9999); // تایم‌دار محدود به زمان؛ غیرتایم‌دار 12 سوال
  idx = 0; score = 0;
  updateStats();

  // timer if needed
  if(currentGame.type==="timed_mcq"){
    startTimer(currentGame.seconds || 30);
  }

  renderQuestion();
  document.getElementById("startBtn").innerText = "در حال بازی";
}

function next(){
  idx++;
  updateStats();

  // پایان در بازی‌های غیرتایم‌دار بعد از 12 سوال
  if(currentGame.type!=="timed_mcq" && idx>=12){
    finishGame("۱۲ سؤال تمام شد. برای یک دور تازه «شروع دوباره» را بزن.");
    return;
  }

  if(currentGame.type==="timed_mcq" && (!timeMode || remaining<=0)){
    // تایمر تمام شده
    finishGame("زمان تمام شد.");
    return;
  }

  renderQuestion();
}

/* ---------- رندر سؤال ---------- */
let currentQ = null;

function renderQuestion(){
  const type = currentGame.type;
  const q = getNextQuestionFromPool();
  if(!q){
    finishGame("بانک سؤال فعلی تمام شد؛ تاریخچه را ریست کن یا دوباره شروع کن تا سؤال‌های تازه ساخته شود.");
    return;
  }
  currentQ = q;

  if(type==="mcq" || type==="timed_mcq") runMCQ(q);
  else if(type==="tf") runTF(q);
  else if(type==="order") runOrder(q);
  else if(type==="pickWord") runPickWord(q);
  else runMCQ(q);

  updateStats();
}

/* ---------- MCQ ---------- */
function runMCQ(qObj){
  document.getElementById("question").innerText = qObj.q;
  const content = document.getElementById("content");
  content.innerHTML = `<div class="options" id="opts"></div><div class="small" id="exp"></div>`;
  const opts = content.querySelector("#opts");
  const exp = content.querySelector("#exp");

  qObj.options.forEach((text,i)=>{
    const b=document.createElement("button");
    b.className="optbtn";
    b.innerText=text;
    b.onclick=()=>{
      // قفل پاسخ
      [...opts.querySelectorAll("button")].forEach(x=>x.disabled=true);

      const ok = (i===qObj.answer);
      if(ok){
        score++;
        notice("✅ درست!");
        b.classList.add("correct");
      } else {
        notice("❌ غلط!");
        b.classList.add("wrong");
        opts.querySelectorAll("button")[qObj.answer]?.classList.add("correct");
      }

      if(qObj.exp){
        exp.innerText = "نکته: " + qObj.exp;
      } else {
        exp.innerText = "";
      }

      updateStats();
      setTimeout(()=>{ if(!timeMode || remaining>0) next(); }, 650);
    };
    opts.appendChild(b);
  });
}

/* ---------- True/False ---------- */
function runTF(qObj){
  document.getElementById("question").innerText = qObj.q;
  const content = document.getElementById("content");
  content.innerHTML = `
    <div class="options">
      <button class="optbtn" id="tBtn">درست ✅</button>
      <button class="optbtn" id="fBtn">غلط ❌</button>
    </div>
    <div class="small" style="margin-top:10px" id="exp"></div>
  `;
  const tBtn = content.querySelector("#tBtn");
  const fBtn = content.querySelector("#fBtn");
  const exp  = content.querySelector("#exp");

  const choose=(val,btn)=>{
    tBtn.disabled=true; fBtn.disabled=true;
    const ok = (val===qObj.answer);
    if(ok){ score++; notice("✅ درست!"); btn.classList.add("correct"); }
    else{ notice("❌ غلط!"); btn.classList.add("wrong"); (qObj.answer?tBtn:fBtn).classList.add("correct"); }
    if(qObj.exp) exp.innerText = "توضیح: " + qObj.exp;
    updateStats();
    setTimeout(()=>{ next(); }, 750);
  };
  tBtn.onclick=()=>choose(true,tBtn);
  fBtn.onclick=()=>choose(false,fBtn);
}

/* ---------- Order (tap-to-build) ---------- */
function runOrder(qObj){
  document.getElementById("question").innerText = qObj.q;
  const content = document.getElementById("content");

  const poolItems = shuffle([...qObj.items]);
  let built = [];

  content.innerHTML = `
    <div class="small">روی آیتم‌ها بزن تا ترتیب ساخته شود. برای حذف آخرین، «برگشت».</div>
    <div class="row" style="margin-top:10px">
      <div class="stat" style="flex:1;min-width:240px">ساخته‌شده: <span id="built">—</span></div>
      <button class="btn ghost" id="undo">برگشت</button>
      <button class="btn" id="check">بررسی</button>
    </div>
    <div class="list" id="list"></div>
  `;
  const list = content.querySelector("#list");
  const builtEl = content.querySelector("#built");

  function renderBuilt(){ builtEl.innerText = built.length ? built.join(" ") : "—"; }
  renderBuilt();

  poolItems.forEach((w)=>{
    const it=document.createElement("div");
    it.className="item";
    it.innerHTML=`<span>${w}</span><span class="small">اضافه</span>`;
    it.onclick=()=>{
      built.push(w);
      it.style.opacity=".35";
      it.style.pointerEvents="none";
      renderBuilt();
    };
    list.appendChild(it);
  });

  content.querySelector("#undo").onclick=()=>{
    if(!built.length) return;
    const last = built.pop();
    [...list.children].forEach(ch=>{
      if(ch.firstChild?.textContent===last && ch.style.pointerEvents==="none"){
        ch.style.opacity="1";
        ch.style.pointerEvents="auto";
        return;
      }
    });
    renderBuilt();
  };

  content.querySelector("#check").onclick=()=>{
    const ok = arrayEq(built, qObj.answer);
    if(ok){ score++; notice("✅ عالی! ترتیب درست بود."); updateStats(); setTimeout(()=>next(),650); }
    else{
      notice("❌ ترتیب درست نیست. دوباره تلاش کن.");
    }
  };
}
function arrayEq(a,b){
  if(a.length!==b.length) return false;
  for(let i=0;i<a.length;i++) if(a[i]!==b[i]) return false;
  return true;
}

