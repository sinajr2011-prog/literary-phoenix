<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>پنل مینی‌گیم‌ها (۲۰ بازی سمپادی، سه‌پایه) | ققنوس ادب</title>

<link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet">

<style>
:root{
  --primary:#6c63ff; --secondary:#4f46e5; --accent:#22c55e;
  --grad-main:linear-gradient(135deg,#667eea,#764ba2);
  --text-main:#111827; --text-muted:#6b7280;
  --radius-lg:22px; --radius-md:16px; --radius-sm:12px;
  --shadow-soft:0 12px 30px rgba(0,0,0,.10);
  --bg-card:#ffffff; --bg-page:#f8fafc;
}
*{box-sizing:border-box;font-family:Vazirmatn,sans-serif}
body{margin:0;background:var(--grad-main);color:var(--text-main)}
a{color:inherit;text-decoration:none}

/* Header */
.header{
  background:#fff;margin:20px;padding:16px 18px;border-radius:var(--radius-lg);
  box-shadow:var(--shadow-soft);display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;
}
.header h2{margin:0;font-size:17px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.badge{display:inline-block;padding:4px 10px;border-radius:999px;background:#ecfeff;color:#155e75;font-size:11px}
.pills{display:flex;gap:8px;flex-wrap:wrap}
.pill{
  padding:8px 12px;border-radius:999px;border:1px solid rgba(17,24,39,.08);
  background:#fff;cursor:pointer;font-size:13px;color:var(--text-main);
}
.pill.active{background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;border-color:transparent}
.btnTop{
  background:linear-gradient(135deg,var(--primary),var(--secondary));
  color:#fff;border:none;padding:10px 14px;border-radius:999px;cursor:pointer;font-size:13px;
}
.btnTop.ghost{background:#fff;color:#111827;border:1px solid rgba(0,0,0,.12)}
.small{font-size:12px;color:var(--text-muted)}

/* Layout */
.container{
  margin:20px;background:var(--bg-page);border-radius:var(--radius-lg);
  padding:18px;box-shadow:var(--shadow-soft);
}
.section-title{font-size:15px;margin:10px 0 12px;display:flex;align-items:center;gap:8px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}

/* Card */
.card{
  background:var(--bg-card);border-radius:var(--radius-lg);padding:16px;box-shadow:var(--shadow-soft);
  position:relative;transition:.22s;overflow:hidden;
}
.card::before{
  content:"";position:absolute;top:0;right:0;left:0;height:5px;border-radius:var(--radius-lg) var(--radius-lg) 0 0;
}
.card:hover{transform:translateY(-6px)}
.card h3{margin:0 0 6px;font-size:15px}
.card p{margin:0;color:var(--text-muted);font-size:13px;line-height:1.7}
.tagrow{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.tag{
  font-size:11px;padding:5px 10px;border-radius:999px;background:#eef2ff;color:#3730a3;
}
.play-btn{
  margin-top:12px;width:100%;
  background:linear-gradient(135deg,var(--primary),var(--secondary));
  color:#fff;border:none;padding:12px 14px;border-radius:999px;font-size:13px;cursor:pointer;
}
.play-btn:hover{opacity:.92}

/* Subject colors */
.persian::before{background:#ef4444}
.math::before{background:#3b82f6}
.science::before{background:#10b981}
.general::before{background:#f59e0b}

/* Game View */
#gameView{display:none}
.game-wrap{
  background:#fff;border-radius:var(--radius-lg);box-shadow:var(--shadow-soft);
  padding:16px;
}
.game-top{
  display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap
}
.game-title{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.game-title h3{margin:0;font-size:16px}
.statbar{display:flex;gap:10px;flex-wrap:wrap}
.stat{
  padding:8px 10px;border-radius:12px;background:#f3f4f6;font-size:12px;color:#111827
}
.hr{height:1px;background:rgba(0,0,0,.08);margin:12px 0}
.qbox{
  padding:14px;border-radius:var(--radius-md);background:#f8fafc;border:1px solid rgba(0,0,0,.06);
}
.qtext{font-size:15px;line-height:1.95}
.options{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px;margin-top:12px}
.optbtn{
  padding:12px;border-radius:14px;border:1px solid rgba(0,0,0,.10);
  background:#fff;cursor:pointer;font-size:13px;text-align:center;
}
.optbtn:hover{border-color:rgba(79,70,229,.6)}
.optbtn.correct{border-color:rgba(34,197,94,.8);background:rgba(34,197,94,.10)}
.optbtn.wrong{border-color:rgba(239,68,68,.8);background:rgba(239,68,68,.10)}
.row{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
.btn{
  padding:12px 14px;border-radius:999px;border:none;cursor:pointer;font-size:13px;
  background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;
}
.btn.ghost{background:#fff;color:#111827;border:1px solid rgba(0,0,0,.12)}
.notice{margin-top:10px;font-size:13px;line-height:1.8}
.kbd{font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono"; background:#111827; color:#fff; padding:2px 6px; border-radius:8px; font-size:11px}
.list{display:grid;gap:10px;margin-top:12px}
.item{
  padding:12px;border-radius:14px;border:1px solid rgba(0,0,0,.10);background:#fff;
  display:flex;justify-content:space-between;align-items:center;gap:10px;cursor:pointer;
}
.pairwrap{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}
.paircol{padding:12px;border-radius:14px;background:#f8fafc;border:1px solid rgba(0,0,0,.06)}
.paircol h4{margin:0 0 10px;font-size:13px;color:#111827}
.pairbtn{
  width:100%;text-align:right;padding:10px;border-radius:12px;border:1px solid rgba(0,0,0,.10);
  background:#fff;cursor:pointer;margin:6px 0;font-size:13px;
}
.pairbtn.selected{border-color:rgba(79,70,229,.6);background:rgba(79,70,229,.08)}
.pairbtn.matched{border-color:rgba(34,197,94,.7);background:rgba(34,197,94,.10);cursor:default}
.footerhint{margin-top:12px;color:var(--text-muted);font-size:12px;line-height:1.9}

/* Grade Modal */
.modal{
  position:fixed; inset:0; background:rgba(0,0,0,.45);
  display:none; align-items:center; justify-content:center; z-index:9999;
}
.modal-box{
  width:min(520px,92vw);
  background:#fff; padding:22px; border-radius:22px;
  box-shadow:0 20px 50px rgba(0,0,0,.25); text-align:center;
}
.modal-box h2{margin:0 0 6px;font-size:18px}
.modal-box p{margin:0;color:var(--text-muted);font-size:13px;line-height:1.8}
.grade-buttons{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:16px}
.grade-buttons button{
  padding:12px 18px;border-radius:999px;border:none;cursor:pointer;font-size:14px;
  background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;min-width:120px;
}
.grade-buttons button.ghost{
  background:#fff;color:#111827;border:1px solid rgba(0,0,0,.12)
}
</style>
</head>

<body>

<!-- Grade Modal -->
<div id="gradeModal" class="modal">
  <div class="modal-box">
    <h2>🎓 پایه تحصیلی را انتخاب کن</h2>
    <p>
      سوال‌ها <b>سمپادی‌تر</b> هستند و برای هر پایه جدا تنظیم شده‌اند.
      <br/>بدون انتخاب پایه، بازی‌ها شروع نمی‌شوند.
    </p>
    <div class="grade-buttons">
      <button onclick="setGrade(7)">هفتم</button>
      <button onclick="setGrade(8)">هشتم</button>
      <button onclick="setGrade(9)">نهم</button>
    </div>
    <div class="footerhint" style="margin-top:12px">
      هر زمان خواستی پایه را عوض کنی از بالای صفحه روی «تغییر پایه» بزن.
    </div>
  </div>
</div>

<!-- Header -->
<div class="header">
  <h2>
    🎮 پنل مینی‌گیم‌ها | ققنوس ادب
    <span class="badge">۲۰ بازی • سمپادی • ضدتکرار</span>
    <span class="badge" id="gradeBadge">پایه: —</span>
  </h2>

  <div class="pills" id="filters">
    <button class="pill active" data-filter="all">همه</button>
    <button class="pill" data-filter="persian">📕 فارسی</button>
    <button class="pill" data-filter="math">📘 ریاضی</button>
    <button class="pill" data-filter="science">🔬 علوم</button>
    <button class="pill" data-filter="general">⭐ عمومی</button>
  </div>

  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <button class="btnTop ghost" onclick="openGradeModal()">تغییر پایه</button>
    <button class="btnTop" onclick="goHome()">خانه</button>
  </div>
</div>

<!-- Home -->
<div class="container" id="homeView">
  <div class="section-title">🧩 بازی‌ها (روی «شروع بازی» بزن)</div>
  <div class="grid" id="cards"></div>
  <div class="footerhint">
    ✅ همه‌چیز داخل همین فایل است. هیچ API و اینترنتی لازم نیست.<br/>
    ✅ بانک سؤال «ضدتکرار» است: تا وقتی مجموعه‌ی فعلی تمام نشود، سؤال تکراری نمی‌آید. همچنین بسیاری از بازی‌ها «مولد سؤال» دارند که عملاً تعداد سؤال را خیلی زیاد می‌کند.
  </div>
</div>

<!-- Game -->
<div class="container" id="gameView">
  <div class="game-wrap">
    <div class="game-top">
      <div class="game-title">
        <button class="btn ghost" onclick="goHome()">← بازگشت</button>
        <div>
          <h3 id="gTitle">—</h3>
          <div class="small" id="gDesc">—</div>
        </div>
      </div>
      <div class="statbar">
        <div class="stat">🎓 پایه: <span id="sGrade">—</span></div>
        <div class="stat">⏱️ زمان: <span id="sTime">—</span></div>
        <div class="stat">⭐ امتیاز: <span id="sScore">0</span></div>
        <div class="stat">📌 سوال: <span id="sQ">0/0</span></div>
        <div class="stat">🏆 رکورد: <span id="sBest">0</span></div>
      </div>
    </div>

    <div class="hr"></div>

    <div class="qbox">
      <div class="qtext" id="question">برای شروع، دکمه‌ی «شروع» را بزن.</div>
      <div id="content"></div>

      <div class="row">
        <button class="btn" id="startBtn" onclick="startCurrent()">شروع</button>
        <button class="btn ghost" onclick="restartGame()">شروع دوباره</button>
        <button class="btn ghost" onclick="resetBest()">ریست رکورد این بازی</button>
        <button class="btn ghost" onclick="resetAllUsed()">ریست تاریخچه ضدتکرار</button>
      </div>

      <div class="notice" id="notice"></div>
      <div class="footerhint" id="hint"></div>
    </div>
  </div>
</div>

<script>
/* =========================================================
   0) پایه (اجباری)
   ========================================================= */
let currentGrade = null;

function openGradeModal(){
  document.getElementById("gradeModal").style.display = "flex";
}
function closeGradeModal(){
  document.getElementById("gradeModal").style.display = "none";
}
function setGrade(g){
  currentGrade = g;
  localStorage.setItem("PHOENIX_GRADE", String(g));
  document.getElementById("gradeBadge").innerText = "پایه: " + g;
  closeGradeModal();
  // اگر توی بازی بودیم، برگرد خانه تا سوال‌ها با پایه جدید قاطی نشه
  goHome();
}
function initGrade(){
  const g = localStorage.getItem("PHOENIX_GRADE");
  if(!g){
    openGradeModal();
    document.getElementById("gradeBadge").innerText = "پایه: —";
  } else {
    currentGrade = Number(g);
    document.getElementById("gradeBadge").innerText = "پایه: " + currentGrade;
  }
}
initGrade();

/* =========================================================
   1) لیست بازی‌ها (۲۰ بازی)
